NODE_ENV=development
PORT=3001
JWT_SECRET=change-this-to-a-long-random-secret
DATABASE_PATH=./src/db/nextdoorlearn.db
UPLOAD_DIR=./uploads

# Comma-separated browser origins allowed to call the API.
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://127.0.0.1:5173
# Optional comma-separated JavaScript regex patterns for additional origins.
# Vercel *.vercel.app origins are allowed by default in production.
CORS_ORIGIN_PATTERNS=

# Requests per 15 minutes.
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=30
ADMIN_EMAILS=

# Optional Google Calendar OAuth.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/google/callback

# Optional transactional email via Resend.
RESEND_API_KEY=
EMAIL_FROM=NextDoorLearn <no-reply@example.com>
